{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "preserve",
    "rootDir": "./",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "vite/client"],
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "env.d.ts",
    "*.ts",
    "site/.vitepress/**/*.ts",
    "site/.vitepress/**/*.tsx",
    "site/.vitepress/**/*.vue",
    "site/**/*.ts",
    "site/**/*.tsx",
    "site/**/*.vue"
  ]
}
